{
    // IntelliSense を使用して利用可能な属性を学べます。
    // 既存の属性の説明をホバーして表示します。
    // 詳細情報は次を確認してください: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.0.1",
    "compounds": [
        {
            "name": "server + web",
            "configurations": [
                "Python: cmdbox server",
                "Python: cmdbox web"]
        },
        {
            "name": "server + web + mcp",
            "configurations": [
                "Python: cmdbox server",
                "Python: cmdbox server",
                "Python: cmdbox web",
                "Python: cmdbox mcpsv"]
        },
        {
            "name": "server + web + mcp + a2a",
            "configurations": [
                "Python: cmdbox server",
                "Python: cmdbox server",
                "Python: cmdbox web",
                "Python: cmdbox mcpsv",
                "Python: cmdbox a2asv"
            ]
        }
    ],
    "configurations": [
        {
            "name": "Python: cmdbox server",
            "type": "python",
            "request": "launch",
            "args": ["-m","server","-c","start","-f","--retry_count","3","--debug"],
            "module": "cmdbox",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "justMyCode": false
        },
        {
            "name": "Python: cmdbox tts_install",
            "type": "python",
            "request": "launch",
            "args": ["-m","tts","-c","install","--client_only","-f"],
            "module": "cmdbox",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "justMyCode": false
        },
        {
            "name": "Python: cmdbox attach",
            "type": "python",
            "request": "attach",
            "connect": {
                "host": "localhost",
                "port": 5678
            },
            "module": "cmdbox",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "justMyCode": false
        },
        {
            "name": "Python: cmdbox web",
            "type": "python",
            "request": "launch",
            "args": ["-m","web","-c","start", "--signin_file",".cmdbox/user_list.yml",
                    "--gunicorn_workers","10","--debug",
                    //"--debug_attach","--debug_attach_port","5678","--logsv",
                    "--ssl_cert","idp_cert.pem","--ssl_key","idp_private.pem",
                    //"--client_only",
            ],
            "module": "cmdbox",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "justMyCode": false
        },
        {
            "name": "Python: cmdbox mcpsv",
            "type": "python",
            "request": "launch",
            "args": ["-m","mcpsv","-c","start","--signin_file",".cmdbox/user_list.yml",
                     "--debug","--gunicorn_workers","3",
                     //"--ssl_cert","idp_cert.pem","--ssl_key","idp_private.pem",
                     //"--client_only",
            ],
            "module": "cmdbox",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "justMyCode": false
        },
        {
            "name": "Python: cmdbox a2asv",
            "type": "python",
            "request": "launch",
            "args": ["-m","a2asv","-c","start","--signin_file",".cmdbox/user_list.yml",
                     "--debug","--gunicorn_workers","3",
                     //"--ssl_cert","idp_cert.pem","--ssl_key","idp_private.pem",
                     //"--client_only",
            ],
            "module": "cmdbox",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "justMyCode": false
        },
        {
            "name": "Python: cmdbox edge config",
            "type": "python",
            "request": "launch",
            "args": ["-m","edge","-c","config","--debug"],
            "module": "cmdbox",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "justMyCode": false
        },
        {
            "name": "Python: cmdbox edge start",
            "type": "python",
            "request": "launch",
            "args": ["-m","edge","-c","start"],
            "module": "cmdbox",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "justMyCode": false
        },
        {
            "name": "Python: cmdbox cmdbox setup",
            "type": "python",
            "request": "launch",
            "args": ["-m","cmdbox","-c","setup","--chopt","host=redis"],
            "module": "cmdbox",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "justMyCode": false
        }
    ]
}